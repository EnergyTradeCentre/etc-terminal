{
        "version": 2,
        "rewrites": [
                  { "source": "/api/(.*)", "destination": "/api/$1" },
                  { "source": "/(.*)", "destination": "/index.html" }
        ],
        "headers": [
                  {
                              "source": "/api/prices",
                              "headers": [
                                            { "key": "Cache-Control", "value": "s-maxage=600, stale-while-revalidate=300" }
                              ]
                  },
                  {
                              "source": "/api/japan-prices",
                              "headers": [
                                            { "key": "Cache-Control", "value": "s-maxage=600, stale-while-revalidate=300" }
                              ]
                  }
        ]
}
